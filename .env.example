# Required for Gemini topic and lesson generation.
GEMINI_API_KEY=

# Optional overrides. Default text generation uses Flash-Lite for speed.
GEMINI_TEXT_MODEL=gemini-2.5-flash-lite
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# Optional. Add your Neon pooled connection string to enable topic/session history.
DATABASE_URL=
