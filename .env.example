# Required for Gemini topic, lesson, and TTS generation.
GEMINI_API_KEY=

# Optional overrides in case Google changes preview model availability.
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# Optional. Add your Neon pooled connection string to enable topic/session history.
DATABASE_URL=
