# Required for Grok/xAI narration.
XAI_API_KEY=

# Required for Gemini topic and lesson generation.
GEMINI_API_KEY=

# Optional overrides. Default text generation uses Gemini 2.5 Flash.
GEMINI_TEXT_MODEL=gemini-2.5-flash

# Optional. Add your Neon pooled connection string to enable topic/session history.
DATABASE_URL=
